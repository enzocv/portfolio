---
---
<section class="min-h-screen flex items-center px-gutter pt-24 max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-xl items-center w-full">
      <div class="animate-reveal" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-2 mb-4">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
          </span>
          <span class="text-primary font-space tracking-widest text-sm">DISPONIBLE PARA PROYECTOS</span>
        </div>
        <h1 class="font-space text-4xl md:text-5xl font-bold text-primary mb-2">Enzo Catalán</h1>
        <h2 class="font-space text-2xl text-secondary mb-6">Ingeniero de Sistemas | Full Stack Developer</h2>
        <p class="text-lg text-on-surface-variant mb-8 leading-relaxed">
          Construyo soluciones digitales escalables, modernas y eficientes con un enfoque en arquitectura robusta y experiencia de usuario excepcional.
        </p>
        <div class="flex flex-wrap gap-sm">
          <a href="#work" class="bg-primary-container text-on-primary-container px-8 py-4 rounded-full font-bold inline-flex items-center gap-2 hover:opacity-90 transition-all shadow-[0_0_20px_rgba(0,229,255,0.3)]">
            Ver proyectos <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="#contact" class="border border-outline text-on-surface px-8 py-4 rounded-full font-bold hover:bg-surface-container-highest transition-all inline-flex items-center">
            Contactarme
          </a>
        </div>
      </div>
      <div class="relative hidden md:flex justify-center animate-reveal" style="animation-delay: 0.4s;">
        <div class="animate-float relative">
          <div class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full"></div>
          <img alt="Enzo Catalán" class="w-80 h-auto object-contain relative z-10" src="/Perfil.png"/>
          <div class="absolute -top-4 -right-4 glass px-4 py-2 rounded-lg font-space text-primary animate-float" style="animation-delay: -1s;">&lt;React /&gt;</div>
          <div class="absolute bottom-8 -left-8 glass px-4 py-2 rounded-lg font-space text-secondary animate-float" style="animation-delay: -2s;">Node.js</div>
          <div class="absolute top-1/2 -right-8 glass px-4 py-2 rounded-lg font-space text-primary animate-float" style="animation-delay: -2s;">AWS</div>
        </div>
      </div>
    </div>
  </section>
