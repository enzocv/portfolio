---
import { SOCIAL_LINKS } from '../data/social';

// Repos a destacar: agrega, quita o reordena entradas para cambiar qué se muestra.
const FEATURED_REPOS = [
  { repo: 'enzocv/fintrack', tag: 'Mobile', offset: false },
  { repo: 'enzocv/hotelv2', tag: 'Web', offset: true },
  { repo: 'enzocv/babymind', tag: 'Mobile', offset: false },
];

const token = import.meta.env.GH_REPOS_TOKEN;

const projects = await Promise.all(
  FEATURED_REPOS.map(async ({ repo, tag, offset }) => {
    const res = await fetch(`https://api.github.com/repos/${repo}`, {
      headers: {
        Authorization: `Bearer ${token}`,
        Accept: 'application/vnd.github+json',
      },
    });

    if (!res.ok) {
      throw new Error(`GitHub API error for ${repo}: ${res.status}`);
    }

    const data = await res.json();
    const topics: string[] = data.topics?.length ? data.topics : [data.language].filter(Boolean);

    return {
      title: data.name as string,
      tag,
      desc: (data.description as string) ?? '',
      techs: topics.map((t) => `#${t}`),
      img: `https://opengraph.githubassets.com/1/${repo}`,
      demoUrl: data.homepage as string | null,
      codeUrl: data.private ? null : (data.html_url as string),
      offset,
    };
  })
);
---
<section class="py-xl px-gutter max-w-7xl mx-auto" id="work">
  <h2 class="font-space text-3xl text-primary mb-xl text-center font-semibold">Proyectos Destacados</h2>
  <div class="grid md:grid-cols-2 gap-lg lg:gap-xl">
    {projects.map((project) => (
      <div class={`glass group overflow-hidden rounded-xl ${project.offset ? 'md:mt-24' : ''}`}>
        <div class="h-64 overflow-hidden relative">
          <img src={project.img} alt={project.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          {(project.demoUrl || project.codeUrl) && (
            <div class="absolute inset-0 bg-surface/40 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity flex items-center justify-center gap-md">
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" aria-label="Ver demo" class="w-12 h-12 flex items-center justify-center bg-primary-container text-on-primary-container rounded-full hover:scale-110 transition-transform"><span class="material-symbols-outlined">visibility</span></a>
              )}
              {project.codeUrl && (
                <a href={project.codeUrl} target="_blank" rel="noopener noreferrer" aria-label="Ver código" class="w-12 h-12 flex items-center justify-center bg-surface rounded-full hover:scale-110 transition-transform border border-outline"><span class="material-symbols-outlined">code</span></a>
              )}
            </div>
          )}
        </div>
        <div class="p-md">
          <div class="flex justify-between items-start mb-4">
            <h3 class="font-space text-2xl text-primary font-semibold">{project.title}</h3>
            <span class="text-xs font-space px-2 py-1 bg-surface-container rounded text-secondary">{project.tag}</span>
          </div>
          <p class="text-on-surface-variant mb-6 text-sm leading-relaxed">{project.desc}</p>
          <div class="flex flex-wrap gap-2">
            {project.techs.map(tech => <span class="text-xs font-space opacity-60">{tech}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="mt-xl flex justify-center">
    <a
      href={SOCIAL_LINKS.github}
      target="_blank"
      rel="noopener noreferrer"
      class="border border-outline text-on-surface px-8 py-4 rounded-full font-bold hover:bg-surface-container-highest transition-all inline-flex items-center gap-2"
    >
      Ver más en GitHub <span class="material-symbols-outlined">arrow_outward</span>
    </a>
  </div>
</section>
