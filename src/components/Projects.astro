---
import { SOCIAL_LINKS } from '../data/social';

const projects = [
  {
    title: "Gym Hub Pro", tag: "SaaS",
    desc: "Plataforma integral para gestión de gimnasios con pagos automatizados, tracking de rutinas y dashboard administrativo.",
    techs: ["#NextJS", "#PostgreSQL", "#Stripe"],
    img: "https://lh3.googleusercontent.com/aida-public/AB6AXuCwzwfExycuQBiJ1dXCN5iYGO4cEIQDAb-kPJ-sGxOq7zCxfLXMdrIGMq0Vluq3IvXr7QkULAlg1TYKNnc42fTjqWGtp6nZEiVvwhUPtj-VPEhpZx1UT_fXZZ0zGNjM-VcG7IVC40byhg9iL84hNJ45rbTN0CXjelGp862tgvjT2rErBZojETIiQz87gIyLmM6Rc_lZmBh25R0VFPF-q6NN2L3z6Q4eoGb7yvuNXJmhCW8kztkNVU99pWZsS99IC6OhBxVk5qFqAcfI",
    offset: false
  },
  {
    title: "FinTrack Mobile", tag: "Mobile",
    desc: "Aplicación móvil de finanzas personales con inteligencia artificial para categorización de gastos y metas de ahorro.",
    techs: ["#ReactNative", "#Firebase", "#AI"],
    img: "https://lh3.googleusercontent.com/aida-public/AB6AXuB74XVDA9U8ajR8vbwhmLnLOSqOym1dO41z46tMZYWIsBJXjnAGPXAzmiSo-VmfqNNpk5IL2kFudXeZu4YJ0ogExBPH4eNqTeaHvqGQhPs81UmR4JBPU_0UKl9AwtI968Ji6Ri_-No7aeLdbL2uPgs508gr6atQD4vazq1mdfIM3vVAAsRHPsoi8E_Fwec4_ErqDcAWZVAxuIp_VIsRNCj5qbLk07HlVPmzDbYP2olZx90SCBAHx-mkMt1yyhPmfm9YwRB0o8VFhi1W",
    offset: true
  }
];
---
<section class="py-xl px-gutter max-w-7xl mx-auto" id="work">
  <h2 class="font-space text-3xl text-primary mb-xl text-center font-semibold">Proyectos Destacados</h2>
  <div class="grid md:grid-cols-2 gap-lg lg:gap-xl">
    {projects.map((project) => (
      <div class={`glass group overflow-hidden rounded-xl ${project.offset ? 'md:mt-24' : ''}`}>
        <div class="h-64 overflow-hidden relative">
          <img src={project.img} alt={project.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-surface/40 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity flex items-center justify-center gap-md">
            <button type="button" aria-label="Ver demo" class="w-12 h-12 flex items-center justify-center bg-primary-container text-on-primary-container rounded-full hover:scale-110 transition-transform"><span class="material-symbols-outlined">visibility</span></button>
            <button type="button" aria-label="Ver código" class="w-12 h-12 flex items-center justify-center bg-surface rounded-full hover:scale-110 transition-transform border border-outline"><span class="material-symbols-outlined">code</span></button>
          </div>
        </div>
        <div class="p-md">
          <div class="flex justify-between items-start mb-4">
            <h3 class="font-space text-2xl text-primary font-semibold">{project.title}</h3>
            <span class="text-xs font-space px-2 py-1 bg-surface-container rounded text-secondary">{project.tag}</span>
          </div>
          <p class="text-on-surface-variant mb-6 text-sm leading-relaxed">{project.desc}</p>
          <div class="flex flex-wrap gap-2">
            {project.techs.map(tech => <span class="text-xs font-space opacity-60">{tech}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="mt-xl flex justify-center">
    <a
      href={SOCIAL_LINKS.github}
      target="_blank"
      rel="noopener noreferrer"
      class="border border-outline text-on-surface px-8 py-4 rounded-full font-bold hover:bg-surface-container-highest transition-all inline-flex items-center gap-2"
    >
      Ver más en GitHub <span class="material-symbols-outlined">arrow_outward</span>
    </a>
  </div>
</section>
